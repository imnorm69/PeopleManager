@page "/admin/shadow-settings"
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar

<PageTitle>Shadowing Settings — People Manager</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Shadowing Settings</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudPaper Elevation="2" Class="pa-4" Style="max-width:520px;">
        <MudForm @ref="_form" Class="d-flex flex-column gap-4">
            <MudCheckBox @bind-Value="_enabled" Label="Enable Shadow Requirements" Color="Color.Primary" />
            <MudNumericField @bind-Value="_defaultRequirement" Label="Default Shadow Point Requirement Value *"
                              Min="0m" Step="0.5m" Format="F1"
                              Required="true" RequiredError="A default requirement value is required."
                              Variant="Variant.Outlined" />
        </MudForm>
        <div class="d-flex justify-end mt-4">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync">Save</MudButton>
        </div>
    </MudPaper>
}

@code {
    private MudForm _form = null!;
    private bool _loading = true;
    private bool _enabled = true;
    private decimal _defaultRequirement = 2m;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var settings = await db.AppSettings.FirstOrDefaultAsync();
        if (settings is not null)
        {
            _enabled = settings.ShadowRequirementsEnabled;
            _defaultRequirement = settings.DefaultShadowPointRequirement;
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        await _form.Validate();
        if (!_form.IsValid || _defaultRequirement < 0) return;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var settings = await db.AppSettings.FirstOrDefaultAsync();
            if (settings is null)
            {
                settings = new AppSettings();
                db.AppSettings.Add(settings);
            }
            settings.ShadowRequirementsEnabled = _enabled;
            settings.DefaultShadowPointRequirement = _defaultRequirement;
            await db.SaveChangesAsync();
            Snackbar.Add("Shadowing settings saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}
