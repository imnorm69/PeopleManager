@page "/people/{PersonId:int}"
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(_person?.DisplayName ?? "Person") — People Manager</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_person is null)
{
    <MudAlert Severity="Severity.Error">Person not found.</MudAlert>
}
else
{
    <MudPaper Elevation="0" Style="background:#1e3a5f;border-radius:8px;" Class="pa-4 mb-4">
        <div class="d-flex align-center flex-wrap gap-3">
            <div>
                <MudText Typo="Typo.h5" Style="color:white;">@_person.DisplayName</MudText>
                <MudText Typo="Typo.subtitle1" Style="color:rgba(255,255,255,0.75);">
                    @CurrentTitle — Started @_person.StartDate.ToShortDateString()
                </MudText>
            </div>
            <MudSpacer />
            <MudChip T="string" Color="@(_person.IsActive ? Color.Success : Color.Default)"
                     Variant="Variant.Filled" Label="true">
                @(_person.IsActive ? "Active" : "Inactive")
            </MudChip>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Edit"
                       OnClick="EditPersonAsync">Edit</MudButton>
            @if (_person.IsActive)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.PersonOff"
                           OnClick="SeparatePersonAsync">Separate</MudButton>
            }
            else
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.PersonAdd"
                           OnClick="ReHirePersonAsync">Re-hire</MudButton>
            }
        </div>
    </MudPaper>

    <MudTabs Elevation="2" Rounded="true" PanelClass="pa-4" ApplyEffectsToContainer="true">
        <MudTabPanel Text="Employment History" Icon="@Icons.Material.Filled.History">
            <MudTable Items="_periods" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Hired</MudTh>
                    <MudTh>Separated</MudTh>
                    <MudTh>Reason</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.HireDate.ToShortDateString()</MudTd>
                    <MudTd>@(context.SeparationDate.HasValue ? context.SeparationDate.Value.ToShortDateString() : "Present")</MudTd>
                    <MudTd>@FormatReason(context.SeparationReason)</MudTd>
                </RowTemplate>
            </MudTable>

            <div class="d-flex justify-space-between align-center mt-6 mb-3">
                <MudText Typo="Typo.subtitle1">Job Titles</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddJobTitleAsync">Add Job Title</MudButton>
            </div>
            <MudTable Items="_jobTitles" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Title</MudTh>
                    <MudTh>Effective Date</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd Style="@(context == _jobTitles.FirstOrDefault() ? "font-weight:700;" : null)">@context.Title</MudTd>
                    <MudTd Style="@(context == _jobTitles.FirstOrDefault() ? "font-weight:700;" : null)">@context.EffectiveDate.ToShortDateString()</MudTd>
                </RowTemplate>
            </MudTable>
        </MudTabPanel>

        <MudTabPanel Text="Teams" Icon="@Icons.Material.Filled.Groups">
            <div class="d-flex justify-end mb-3">
                <MudButton Variant="Variant.Filled" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddTeamAsync">Add Team</MudButton>
            </div>
            <MudTable Items="_teamAssignments" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Team</MudTh>
                    <MudTh>Effective</MudTh>
                    <MudTh>Removed</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.ProjectTeam?.Name</MudTd>
                    <MudTd>@context.EffectiveDate.ToShortDateString()</MudTd>
                    <MudTd>@(context.RemovedDate.HasValue ? context.RemovedDate.Value.ToShortDateString() : "Current")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudTabPanel>

        <MudTabPanel Text="Meetings" Icon="@Icons.Material.Filled.EventNote">
            <div class="d-flex justify-end mb-3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="NewMeetingAsync">New Meeting</MudButton>
            </div>
            <MudTable Items="_meetings" Dense="true" Hover="true" Elevation="0"
                      T="Meeting" OnRowClick="@(args => Nav.NavigateTo($"/meetings/{args.Item!.MeetingId}"))"
                      RowClass="cursor-pointer">
                <HeaderContent>
                    <MudTh>Date</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.MeetingDate.ToLongDateString()</MudTd>
                </RowTemplate>
            </MudTable>
        </MudTabPanel>

        <MudTabPanel Text="Checklist History" Icon="@Icons.Material.Filled.Checklist">
            @if (_checklistHistory.Count == 0)
            {
                <MudText Color="Color.Secondary">No checklist answers recorded.</MudText>
            }
            else
            {
                <MudTable Items="_checklistHistory" Dense="true" Hover="true" Elevation="0"
                          T="ChecklistItemEvaluation"
                          OnRowClick="@(args => { if (args.Item!.MeetingId.HasValue) Nav.NavigateTo($"/meetings/{args.Item.MeetingId}"); })"
                          RowClass="cursor-pointer">
                    <HeaderContent>
                        <MudTh>Recorded</MudTh>
                        <MudTh>Item</MudTh>
                        <MudTh>Answer</MudTh>
                        <MudTh>Comment</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.RecordedAt.ToString("g")</MudTd>
                        <MudTd>@context.Item.Description</MudTd>
                        <MudTd>@(context.Value ?? "—")</MudTd>
                        <MudTd Style="white-space:normal">@(context.Notes ?? "—")</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="Shadowing" Icon="@Icons.Material.Filled.Visibility">
            <div class="d-flex align-center flex-wrap gap-4 mb-4">
                <MudCheckBox T="bool" Value="_person.ExcludedFromShadowing" ValueChanged="OnExcludedChangedAsync"
                             Label="Excluded from Shadowing" Color="Color.Primary" Dense="true" />
                <MudSpacer />
                <MudSelect T="int" Value="_selectedYear" ValueChanged="OnYearChangedAsync" Label="Year"
                           Style="min-width:110px;" Dense="true" Variant="Variant.Outlined">
                    @foreach (var y in _availableYears)
                    {
                        <MudSelectItem T="int" Value="y">@y</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="int" Value="_selectedQuarter" ValueChanged="OnQuarterChangedAsync" Label="Quarter"
                           Style="min-width:110px;" Dense="true" Variant="Variant.Outlined">
                    @foreach (var q in _availableQuarters)
                    {
                        <MudSelectItem T="int" Value="q">Q@(q)</MudSelectItem>
                    }
                </MudSelect>
                <MudButton Variant="Variant.Filled" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddShadowSessionAsync">Add Shadow Session</MudButton>
            </div>

            @if (!_person.ExcludedFromShadowing)
            {
                <MudPaper Elevation="0" Class="pa-3 mb-4" Style="@QuotaBarStyle">
                    <MudText Style="font-weight:600;">
                        @(_quarterShadowerPoints >= 2m ? "Shadowing requirement met" : "Shadowing requirement not met")
                        — @_quarterShadowerPoints pt@(_quarterShadowerPoints == 1 ? "" : "s") of 2 required
                        (Q@(_selectedQuarter) @_selectedYear)
                    </MudText>
                </MudPaper>
            }

            @if (_quarterSessions.Count == 0)
            {
                <MudText Color="Color.Secondary">No shadow sessions logged for Q@(_selectedQuarter) @_selectedYear.</MudText>
            }
            else
            {
                <MudTable Items="_quarterSessions" Dense="true" Hover="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh></MudTh>
                        <MudTh>Event Type</MudTh>
                        <MudTh>Team</MudTh>
                        <MudTh>Points</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Date.ToShortDateString()</MudTd>
                        <MudTd>
                            @(context.ShadowerId == PersonId
                                ? $"Shadowed {context.ObservedPerson.DisplayName}"
                                : $"Shadowed by {context.Shadower.DisplayName}")
                        </MudTd>
                        <MudTd>@FormatEventType(context.EventType)</MudTd>
                        <MudTd>@context.TeamObserved</MudTd>
                        <MudTd>@(context.ShadowerId == PersonId ? context.Points.ToString() : "—")</MudTd>
                    </RowTemplate>
                </MudTable>
                <MudText Typo="Typo.subtitle2" Class="mt-3">
                    Total Points Earned: @_quarterShadowerPoints
                </MudText>
            }
        </MudTabPanel>
    </MudTabs>
}

@code {
    [Parameter] public int PersonId { get; set; }

    private bool _loading = true;
    private Person? _person;
    private List<PersonJobTitle> _jobTitles = new();
    private List<PersonProjectAssignment> _teamAssignments = new();
    private List<PersonEmploymentPeriod> _periods = new();
    private List<Meeting> _meetings = new();
    private List<ChecklistItemEvaluation> _checklistHistory = new();
    private List<ShadowSession> _shadowSessions = new();
    private List<int> _availableYears = new();
    private List<int> _availableQuarters = new();
    private List<ShadowSession> _quarterSessions = new();
    private decimal _quarterShadowerPoints;
    private int _selectedYear;
    private int _selectedQuarter;

    private string QuotaBarStyle => _quarterShadowerPoints >= 2m
        ? "background:#eafaf1;border-left:6px solid #27ae60;"
        : "background:#fdedec;border-left:6px solid #c0392b;";

    private string CurrentTitle =>
        _jobTitles.OrderByDescending(t => t.EffectiveDate).FirstOrDefault()?.Title ?? "—";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        _person = await db.People.FindAsync(PersonId);
        if (_person is null) { _loading = false; return; }

        _jobTitles = await db.PersonJobTitles
            .Where(t => t.PersonId == PersonId)
            .OrderByDescending(t => t.EffectiveDate)
            .ToListAsync();

        _teamAssignments = await db.PersonProjectAssignments
            .Include(a => a.ProjectTeam)
            .Where(a => a.PersonId == PersonId)
            .OrderByDescending(a => a.EffectiveDate)
            .ToListAsync();

        _periods = await db.PersonEmploymentPeriods
            .Where(p => p.PersonId == PersonId)
            .OrderByDescending(p => p.HireDate)
            .ToListAsync();

        _meetings = await db.Meetings
            .Where(m => m.PersonId == PersonId)
            .OrderByDescending(m => m.MeetingDate)
            .ToListAsync();

        _checklistHistory = await db.ChecklistItemEvaluations
            .Include(e => e.Item)
            .Where(e => e.PersonId == PersonId)
            .OrderByDescending(e => e.RecordedAt)
            .ToListAsync();

        _shadowSessions = await db.ShadowSessions
            .Include(s => s.Shadower)
            .Include(s => s.ObservedPerson)
            .Where(s => s.ShadowerId == PersonId || s.ObservedPersonId == PersonId)
            .OrderByDescending(s => s.Date)
            .ToListAsync();

        _availableYears = new[] { DateTime.Today.Year }
            .Concat(_shadowSessions.Select(s => s.Date.Year))
            .Distinct()
            .OrderByDescending(y => y)
            .ToList();

        if (_selectedYear == 0)
        {
            _selectedYear = DateTime.Today.Year;
            _selectedQuarter = CurrentQuarter(DateTime.Today);
        }

        RecomputeQuarterView();

        _loading = false;
    }

    private static int CurrentQuarter(DateTime d) => (d.Month - 1) / 3 + 1;

    private static int MaxQuarterForYear(int year) =>
        year < DateTime.Today.Year ? 4 : CurrentQuarter(DateTime.Today);

    private void RecomputeQuarterView()
    {
        var maxQuarter = MaxQuarterForYear(_selectedYear);
        _availableQuarters = Enumerable.Range(1, maxQuarter).ToList();
        _selectedQuarter = Math.Clamp(_selectedQuarter, 1, maxQuarter);

        var quarterStart = new DateTime(_selectedYear, (_selectedQuarter - 1) * 3 + 1, 1);
        var quarterEnd = quarterStart.AddMonths(3);

        _quarterSessions = _shadowSessions
            .Where(s => s.Date >= quarterStart && s.Date < quarterEnd)
            .OrderByDescending(s => s.Date)
            .ToList();

        _quarterShadowerPoints = _quarterSessions
            .Where(s => s.ShadowerId == PersonId)
            .Sum(s => s.Points);
    }

    private void OnYearChangedAsync(int year)
    {
        _selectedYear = year;
        RecomputeQuarterView();
    }

    private void OnQuarterChangedAsync(int quarter)
    {
        _selectedQuarter = quarter;
        RecomputeQuarterView();
    }

    private async Task OnExcludedChangedAsync(bool value)
    {
        if (_person is null) return;
        _person.ExcludedFromShadowing = value;

        await using var db = await DbFactory.CreateDbContextAsync();
        var p = await db.People.FindAsync(PersonId);
        if (p is not null)
        {
            p.ExcludedFromShadowing = value;
            await db.SaveChangesAsync();
            Snackbar.Add(value ? "Marked as excluded from shadowing." : "Marked as required to shadow.", Severity.Success);
        }
    }

    private static string FormatReason(SeparationReason? r) => r switch
    {
        SeparationReason.EndOfInternship => "End of Internship",
        SeparationReason.VoluntaryResignation => "Voluntary Resignation",
        SeparationReason.Termination => "Termination",
        SeparationReason.Other => "Other",
        _ => "—"
    };

    private static string FormatEventType(ShadowEventType t) => t switch
    {
        ShadowEventType.DailyStandup => "Daily Standup",
        _ => t.ToString()
    };

    private async Task EditPersonAsync()
    {
        var p = new DialogParameters<AddEditPersonDialog> { { x => x.PersonId, PersonId } };
        var dialog = await DialogService.ShowAsync<AddEditPersonDialog>("Edit Person", p);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadAsync();
    }

    private async Task AddJobTitleAsync()
    {
        var p = new DialogParameters<AddJobTitleDialog> { { x => x.PersonId, PersonId } };
        var dialog = await DialogService.ShowAsync<AddJobTitleDialog>("Add Job Title", p);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadAsync();
    }

    private async Task AddTeamAsync()
    {
        var p = new DialogParameters<AddTeamAssignmentDialog> { { x => x.PersonId, PersonId } };
        var dialog = await DialogService.ShowAsync<AddTeamAssignmentDialog>("Add Team Assignment", p);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadAsync();
    }

    private async Task SeparatePersonAsync()
    {
        var p = new DialogParameters<SeparatePersonDialog>
        {
            { x => x.PersonId, PersonId },
            { x => x.PersonName, _person!.DisplayName }
        };
        var dialog = await DialogService.ShowAsync<SeparatePersonDialog>("Separate Employee", p);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadAsync();
    }

    private async Task ReHirePersonAsync()
    {
        var p = new DialogParameters<ReHirePersonDialog>
        {
            { x => x.PersonId, PersonId },
            { x => x.PersonName, _person!.DisplayName }
        };
        var dialog = await DialogService.ShowAsync<ReHirePersonDialog>("Re-hire Employee", p);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadAsync();
    }

    private async Task NewMeetingAsync()
    {
        Nav.NavigateTo($"/meetings/new?personId={PersonId}&date={DateTime.Today:yyyy-MM-dd}");
        await Task.CompletedTask;
    }

    private async Task AddShadowSessionAsync()
    {
        var p = new DialogParameters<AddShadowSessionDialog> { { x => x.PersonId, PersonId } };
        var dialog = await DialogService.ShowAsync<AddShadowSessionDialog>("Add Shadow Session", p);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadAsync();
    }
}
