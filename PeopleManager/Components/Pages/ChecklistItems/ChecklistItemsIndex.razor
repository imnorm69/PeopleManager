@page "/checklist-items"
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IDialogService DialogService

<PageTitle>Checklist Items — People Manager</PageTitle>

<div class="d-flex align-center gap-3 mb-4">
    <MudText Typo="Typo.h5">Checklist Items</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Success"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="AddItemAsync">
        Add Item
    </MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.AssignmentInd"
               OnClick="AssignItemsAsync">
        Assign to Person
    </MudButton>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudTable Items="_items" Hover="true" Dense="false" Elevation="2">
        <HeaderContent>
            <MudTh>Order</MudTh>
            <MudTh>Description</MudTh>
            <MudTh>Value Type</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Order">@context.SortOrder</MudTd>
            <MudTd DataLabel="Description" Style="white-space:normal">@context.Description</MudTd>
            <MudTd DataLabel="Value Type">@FormatValueType(context.ValueType)</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private bool _loading = true;
    private List<ChecklistItem> _items = new();

    private static string FormatValueType(ChecklistValueType t) => t switch
    {
        ChecklistValueType.YesNo => "Yes / No",
        ChecklistValueType.Integer => "Integer",
        ChecklistValueType.Percentage => "Percentage",
        ChecklistValueType.Text => "Text",
        ChecklistValueType.Date => "Date",
        _ => t.ToString()
    };

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        _items = await db.ChecklistItems
            .OrderBy(i => i.SortOrder)
            .ToListAsync();
        _loading = false;
    }

    private async Task AddItemAsync()
    {
        var dialog = await DialogService.ShowAsync<AddChecklistItemDialog>("Add Item");
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadAsync();
    }

    private async Task AssignItemsAsync()
    {
        var dialog = await DialogService.ShowAsync<AssignChecklistItemsDialog>("Assign Items");
        await dialog.Result;
    }
}
