@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Edit Team Assignment</MudText>
    </TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else
        {
            <MudForm @ref="_form" Class="d-flex flex-column gap-4 mt-2">
                <MudAutocomplete T="string" Label="Team *" @bind-Value="_teamName"
                                 SearchFunc="SearchTeams" Required="true" RequiredError="Team is required."
                                 CoerceValue="true"
                                 Variant="Variant.Outlined"
                                 Placeholder="Select existing or type new team name" />
                <MudDatePicker @bind-Date="_effectiveDate" Label="Effective Date *"
                               Required="true" RequiredError="Effective date is required."
                               Variant="Variant.Outlined" />
                <MudDatePicker @bind-Date="_removedDate" Label="Removed Date"
                               Clearable="true"
                               Variant="Variant.Outlined" />
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Error" Variant="Variant.Text" OnClick="DeleteAsync" Disabled="_loading">Delete</MudButton>
        <MudSpacer />
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitAsync" Disabled="_loading">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public int AssignmentId { get; set; }

    private MudForm _form = null!;
    private bool _loading = true;
    private string _teamName = "";
    private DateTime? _effectiveDate;
    private DateTime? _removedDate;
    private List<string> _existingTeams = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _existingTeams = await db.ProjectTeams
            .OrderBy(t => t.Name)
            .Select(t => t.Name)
            .ToListAsync();

        var assignment = await db.PersonProjectAssignments
            .Include(a => a.ProjectTeam)
            .FirstOrDefaultAsync(a => a.AssignmentId == AssignmentId);
        if (assignment is not null)
        {
            _teamName = assignment.ProjectTeam.Name;
            _effectiveDate = assignment.EffectiveDate;
            _removedDate = assignment.RemovedDate;
        }
        _loading = false;
    }

    private Task<IEnumerable<string>> SearchTeams(string value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(_existingTeams.AsEnumerable());
        return Task.FromResult(
            _existingTeams.Where(t => t.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitAsync()
    {
        await _form.Validate();
        if (!_form.IsValid || string.IsNullOrWhiteSpace(_teamName)) return;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var assignment = await db.PersonProjectAssignments.FindAsync(AssignmentId);
            if (assignment is null) return;

            var team = await db.ProjectTeams.FirstOrDefaultAsync(t => t.Name == _teamName.Trim());
            if (team is null)
            {
                team = new ProjectTeam { Name = _teamName.Trim() };
                db.ProjectTeams.Add(team);
                await db.SaveChangesAsync();
            }

            assignment.ProjectTeamId = team.ProjectTeamId;
            assignment.EffectiveDate = _effectiveDate ?? assignment.EffectiveDate;
            assignment.RemovedDate = _removedDate;
            await db.SaveChangesAsync();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var assignment = await db.PersonProjectAssignments.FindAsync(AssignmentId);
            if (assignment is not null) db.PersonProjectAssignments.Remove(assignment);
            await db.SaveChangesAsync();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}
