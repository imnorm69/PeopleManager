@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Add Action Item — @PersonFirstName</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" Class="d-flex flex-column gap-4 mt-2">
            <MudTextField @bind-Value="_description" Label="Description *"
                          Required="true" RequiredError="Description is required."
                          Lines="4" Variant="Variant.Outlined" />
            <MudSelect T="ActionItemAssignee" @bind-Value="_assignee" Label="Assigned To"
                       Variant="Variant.Outlined">
                <MudSelectItem T="ActionItemAssignee" Value="ActionItemAssignee.Me">Me</MudSelectItem>
                <MudSelectItem T="ActionItemAssignee" Value="ActionItemAssignee.Person">@PersonFirstName</MudSelectItem>
            </MudSelect>
            <MudDatePicker @bind-Date="_dueDate" Label="Due Date *"
                           Required="true" RequiredError="Due date is required."
                           Variant="Variant.Outlined" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="SubmitAsync">Add</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public int PersonId { get; set; }
    [Parameter] public int MeetingId { get; set; }
    [Parameter] public string PersonFirstName { get; set; } = "Person";

    private MudForm _form = null!;
    private string _description = "";
    private ActionItemAssignee _assignee = ActionItemAssignee.Me;
    private DateTime? _dueDate = DateTime.Today.AddDays(14);

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitAsync()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            db.ActionItems.Add(new ActionItem
            {
                PersonId = PersonId,
                CreatedInMeetingId = MeetingId,
                Description = _description.Trim(),
                AssignedTo = _assignee,
                CreatedDate = DateTime.Today,
                DueDate = _dueDate ?? DateTime.Today.AddDays(14)
            });
            await db.SaveChangesAsync();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}
