@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Complete Action Item</MudText>
    </TitleContent>
    <DialogContent>
        @if (_item is not null)
        {
            <MudText Typo="Typo.body1" Class="mb-4" Style="white-space:normal;">@_item.Description</MudText>
        }
        <MudForm @ref="_form" Class="d-flex flex-column gap-4">
            <MudDatePicker @bind-Date="_completedDate" Label="Completed Date *"
                           Required="true" RequiredError="Completed date is required."
                           Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_completionNotes" Label="Completion Notes"
                          Lines="3" Variant="Variant.Outlined"
                          Placeholder="Optional notes about how this was completed…" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitAsync">Mark Complete</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public int ActionItemId { get; set; }
    [Parameter] public int? MeetingId { get; set; }

    private MudForm _form = null!;
    private ActionItem? _item;
    private DateTime? _completedDate = DateTime.Today;
    private string _completionNotes = "";

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _item = await db.ActionItems.FindAsync(ActionItemId);
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitAsync()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var item = await db.ActionItems.FindAsync(ActionItemId);
            if (item is not null)
            {
                item.IsComplete = true;
                item.CompletedDate = _completedDate;
                item.CompletionNotes = string.IsNullOrWhiteSpace(_completionNotes) ? null : _completionNotes.Trim();
                item.CompletedInMeetingId = MeetingId;
                await db.SaveChangesAsync();
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}
