@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Edit Shadow Session</MudText>
    </TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else
        {
            <MudForm @ref="_form" Class="d-flex flex-column gap-4 mt-2">
                <MudDatePicker @bind-Date="_date" Label="Date *"
                               Required="true" RequiredError="Date is required."
                               Variant="Variant.Outlined" />
                <MudTextField @bind-Value="_shadowerName" Label="Shadower (who observed) *"
                              Required="true" RequiredError="Shadower is required."
                              Variant="Variant.Outlined" />
                <MudTextField @bind-Value="_observedName" Label="Observed (who was shadowed) *"
                              Required="true" RequiredError="Observed person is required."
                              Variant="Variant.Outlined" />
                <MudTextField @bind-Value="_teamObserved" Label="Team Observed *"
                              Required="true" RequiredError="Team observed is required."
                              Variant="Variant.Outlined" />
                <MudSelect T="int" @bind-Value="_eventTypeId" Label="Event Type *"
                           Required="true" RequiredError="Event type is required."
                           Variant="Variant.Outlined">
                    @foreach (var t in _eventTypes)
                    {
                        <MudSelectItem T="int" Value="t.ShadowEventTypeId">@t.Name</MudSelectItem>
                    }
                </MudSelect>
                @if (_requirementsEnabled && SelectedEventType is not null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Points: @SelectedEventType.Points
                    </MudText>
                }
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Error" Variant="Variant.Text" OnClick="DeleteAsync" Disabled="_loading">Delete</MudButton>
        <MudSpacer />
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitAsync" Disabled="_loading">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public int ShadowSessionId { get; set; }

    private MudForm _form = null!;
    private bool _loading = true;
    private DateTime? _date;
    private string _shadowerName = "";
    private string _observedName = "";
    private string _teamObserved = "";
    private int _eventTypeId;
    private List<Person> _people = new();
    private List<ShadowEventType> _eventTypes = new();
    private bool _requirementsEnabled = true;

    private ShadowEventType? SelectedEventType =>
        _eventTypes.FirstOrDefault(t => t.ShadowEventTypeId == _eventTypeId);

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var session = await db.ShadowSessions
            .Include(s => s.Shadower)
            .FirstOrDefaultAsync(s => s.ShadowSessionId == ShadowSessionId);

        // Load everyone (not just active) so a shadower who has since separated still resolves.
        _people = await db.People
            .OrderBy(p => p.LastName).ThenBy(p => p.FirstName)
            .ToListAsync();

        // Include the session's current event type even if it's since been deactivated.
        _eventTypes = await db.ShadowEventTypes
            .Where(t => t.IsActive || t.ShadowEventTypeId == (session != null ? session.EventTypeId : 0))
            .OrderBy(t => t.Name)
            .ToListAsync();

        var settings = await db.AppSettings.FirstOrDefaultAsync();
        _requirementsEnabled = settings?.ShadowRequirementsEnabled ?? true;

        if (session is not null)
        {
            _date = session.Date;
            _shadowerName = session.Shadower.DisplayName;
            _observedName = session.ObservedName;
            _teamObserved = session.TeamObserved;
            _eventTypeId = session.EventTypeId;
        }

        _loading = false;
    }

    private static int QuarterOf(DateTime d) => (d.Month - 1) / 3 + 1;

    /// <summary>
    /// Resolves free-typed text to an existing person, tolerant of "Last, First",
    /// "First Last", or a unique partial match. Returns null if it's ambiguous or no match.
    /// </summary>
    private Person? ResolvePerson(string text)
    {
        text = text.Trim();
        if (text.Length == 0) return null;

        var exact = _people.FirstOrDefault(p =>
            string.Equals(p.DisplayName, text, StringComparison.OrdinalIgnoreCase) ||
            string.Equals($"{p.FirstName} {p.LastName}", text, StringComparison.OrdinalIgnoreCase));
        if (exact is not null) return exact;

        var matches = _people.Where(p =>
            p.DisplayName.Contains(text, StringComparison.OrdinalIgnoreCase) ||
            $"{p.FirstName} {p.LastName}".Contains(text, StringComparison.OrdinalIgnoreCase)).ToList();
        return matches.Count == 1 ? matches[0] : null;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitAsync()
    {
        await _form.Validate();
        if (!_form.IsValid || SelectedEventType is null) return;

        var shadower = ResolvePerson(_shadowerName);
        if (shadower is null)
        {
            Snackbar.Add($"No person found matching \"{_shadowerName}\". Check the spelling.", Severity.Warning);
            return;
        }

        var observedName = _observedName.Trim();

        if (string.Equals(observedName, shadower.DisplayName, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(observedName, $"{shadower.FirstName} {shadower.LastName}", StringComparison.OrdinalIgnoreCase))
        {
            Snackbar.Add("Shadower and observed person must be different.", Severity.Warning);
            return;
        }

        var date = _date ?? DateTime.Today;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            if (_requirementsEnabled)
            {
                var year = date.Year;
                var quarter = QuarterOf(date);
                var hasRequirement = await db.PersonShadowRequirements.AnyAsync(r =>
                    r.PersonId == shadower.PersonId && r.Year == year && r.Quarter == quarter);

                if (!hasRequirement)
                {
                    var p = new DialogParameters<SetQuarterRequirementDialog>
                    {
                        { x => x.PersonName, shadower.DisplayName },
                        { x => x.Year, year },
                        { x => x.Quarter, quarter },
                        { x => x.DefaultPoints, shadower.ShadowPointRequirement }
                    };
                    var reqDialog = await DialogService.ShowAsync<SetQuarterRequirementDialog>("Shadow Point Requirement", p);
                    var reqResult = await reqDialog.Result;
                    if (reqResult is null || reqResult.Canceled) return;

                    db.PersonShadowRequirements.Add(new PersonShadowRequirement
                    {
                        PersonId = shadower.PersonId,
                        Year = year,
                        Quarter = quarter,
                        RequiredPoints = (decimal)reqResult.Data!
                    });
                }
            }

            var session = await db.ShadowSessions.FindAsync(ShadowSessionId);
            if (session is null) return;

            session.Date = date;
            session.ShadowerId = shadower.PersonId;
            session.ObservedName = observedName;
            session.TeamObserved = _teamObserved.Trim();
            session.EventTypeId = SelectedEventType.ShadowEventTypeId;
            session.Points = _requirementsEnabled ? SelectedEventType.Points : null;

            await db.SaveChangesAsync();
            MudDialog.Close(DialogResult.Ok(date));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var session = await db.ShadowSessions.FindAsync(ShadowSessionId);
            if (session is not null) db.ShadowSessions.Remove(session);
            await db.SaveChangesAsync();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}
